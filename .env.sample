# =============================================================================
# GitLab Docker Setup — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored; never commit it.

# --- GitLab server -----------------------------------------------------------
GITLAB_CONTAINER_NAME=gitlab_ce
GITLAB_HOST=your-domain.com
GITLAB_ROOT_EMAIL=admin@your-domain.com
# IMPORTANT: minimum 12 characters with uppercase, lowercase, digits, symbols.
# A weak password makes GitLab refuse to start.
GITLAB_ROOT_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Optional: pin the GitLab CE / Runner image versions for reproducible deploys.
# Leave empty to use `latest` (handy for trial runs, risky in production —
# `docker compose pull` can break with major-version migrations).
# Recommended: pick a tag from https://hub.docker.com/r/gitlab/gitlab-ce/tags
# and bump it intentionally.
GITLAB_VERSION=18.4.1-ce.0
RUNNER_VERSION=v18.11.2

# --- Runner ------------------------------------------------------------------
# Group registration token from GitLab UI:
#   Group → Settings → CI/CD → Runners → New group runner
# (The runner registers itself on first boot using this token.)
RUNNER_REGISTRATION_TOKEN=glrt-XXXXX

# Prometheus internal monitoring (CPU/RAM/disk metrics scraped by GitLab itself).
# Off by default: it adds a non-trivial RAM footprint on small servers and most
# self-hosted setups don't need it. Set to `true` to enable.
GITLAB_PROMETHEUS_ENABLED=false

# --- SMTP (optional — set SMTP_ENABLE=false to skip) -------------------------
SMTP_ENABLE=true
SMTP_ADDRESS=mail.your-domain.com
SMTP_PORT=587
SMTP_USER=gitlab@your-domain.com
SMTP_PASS=YourSMTPPassword
SMTP_DOMAIN=your-domain.com
SMTP_FROM=gitlab@your-domain.com
SMTP_REPLY_TO=noreply@your-domain.com

# --- Port mappings -----------------------------------------------------------
# HTTP_PORT: bound to 127.0.0.1 (front-facing TLS terminates at your reverse
# proxy; see apache-gitlab.conf or nginx-gitlab.conf).
HTTP_PORT=1584
# SSH_PORT: published port on the host for the GitLab container's sshd.
# DO NOT use 22 (collides with the host's own sshd). Pick a non-default port.
SSH_PORT=2222
